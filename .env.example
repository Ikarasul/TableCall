# ===========================
# TableCall — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับระบบของคุณ
# ===========================

# Django
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.trycloudflare.com

# MySQL
MYSQL_DATABASE=tablecall
MYSQL_USER=tablecall_user
MYSQL_PASSWORD=strong_password_here
MYSQL_ROOT_PASSWORD=root_password_here
MYSQL_HOST=db
MYSQL_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=480

# CORS — URL ของ Frontend (React)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Firebase Cloud Messaging (สำหรับ APK push notification)
FCM_SERVER_KEY=your-fcm-server-key-from-firebase-console

# PIN Lock Settings
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=5

# Customer Throttle (วินาที)
CUSTOMER_NOTIFY_THROTTLE_SECONDS=30

# Data Retention (วัน)
NOTIFICATION_RETENTION_DAYS=90
